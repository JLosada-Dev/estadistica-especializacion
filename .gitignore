# =========================================
# Datos (NO subir datos crudos/sensibles)
# =========================================
data/raw/*
data/processed/*
data/external/*
data/interim/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Formatos comunes de datos pesados
*.csv
*.tsv
*.xlsx
*.xls
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.db
*.sqlite
*.sqlite3

# Excepción: datos de ejemplo pequeños que sí quieras versionar
!data/example/*.csv

